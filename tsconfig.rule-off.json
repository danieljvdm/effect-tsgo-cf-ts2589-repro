{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": { "effectInFailure": "off" }
      }
    ]
  },
  "include": ["src/**/*"]
}
